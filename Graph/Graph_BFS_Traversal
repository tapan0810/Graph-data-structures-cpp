#include<iostream>
#include<queue>
#include<vector>
#include<unordered_map>

using namespace std;

class Graph{
    public :
        unordered_map<int,vector<int>> adjList;
        
        void addEdge(int u, int v,bool direction){
            if(direction == 1){
                adjList[u].push_back(v);
            }else{
                adjList[u].push_back(v);
                adjList[v].push_back(u);
            }
        }
        
        void BFSTraversal(int src){
            queue<int> q;
            unordered_map<int,bool> vis;
            
            //initial push
            
            q.push(src);
            vis[src] = true;
            
            //main logic
            
            while(!q.empty()){
                
                int front = q.front();
                q.pop();
                
                cout<<front<<" ";
                
                for(auto nbr : adjList[front]){
                    if(!vis[nbr]){
                        q.push(nbr);
                        vis[nbr] = true;
                    }
                }
                
            }
        }
};

int main(){
    
    Graph g;
    
    g.addEdge(0,1,1);
    g.addEdge(0,2,1);
    g.addEdge(1,2,1);
    g.addEdge(2,3,1);
    g.addEdge(3,4,1);
    g.addEdge(4,5,1);
    
    g.BFSTraversal(0);
    
    
}
